<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
        <h3 class="text-2xl">Login Your Account</h3>
        <form class="mt-10" action="/login" method="post">
            
            <input class="px-3 py-2 rounded bg-transparent border-2 border-zinc-800 outline-none" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 rounded bg-transparent border-2 border-zinc-800 outline-none" type="password" placeholder="password" name="password">
            
            <input class="px-5 py-2 rounded-md bg-blue-500" type="submit" value="Login"> 
        </form>
    </div>
</body>
</html>