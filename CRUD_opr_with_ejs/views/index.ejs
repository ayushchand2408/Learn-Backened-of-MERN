<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class="nav mb-10"> 
            <a class="text-blue-500" href="/read">Read users</a>
            
        </div>

        <h1 class="text-3xl tracking-tighter">Create User</h1>
        <form action="/create" method="post">
            <input
                type="text"
                class="px-5 py-2 border-2 border-zinc-700 rounded-lg bg-transparent text-white"
                placeholder="name"
                name="name"
            >
            <input
                type="text"
                class="px-5 py-2 border-2 border-zinc-700 rounded-lg bg-transparent text-white"
                placeholder="email"
                name="email"
            >
            <input
                type="text"
                class="px-5 py-2 border-2 border-zinc-700 rounded-lg bg-transparent text-white"
                placeholder="image_url"
                name="image"
            >
            <input
                class="px-5 py-2 bg-blue-500 rounded-lg ml-3"
                type="submit"
                value="Create"
            >
        </form>
    </div>
</body>
</html>