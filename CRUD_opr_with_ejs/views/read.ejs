<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 " href="/">Back to home</a>

        <h1 class="text-3xl mb-5 mt-10 tracking-tighter">All Users</h1>
        <div class="users flex gap-4 flex-wrap">
            <% if(users.lentgh > 0){ %>
                <% users.forEach(function(user){ %>
                    <div class="user w-72 p-4 bg-zinc-500 rounded-lg">
                        <div class="w-full h-52 ">
                            <img class="w-full h-full object-cover" src="<%= user.image %>">
                        </div>
                        <h3 class="text-2xl mt-3 tracking-tighter"><%= user.name %></h3>
                        <h5 class="text-zinc-300"><%= user.email %></h5>
                        <div class="flex  mt-10 justify-between">
                            <a class="text-zinc-600 ">Edit User</a>
                            <a class="text-red-500"   href="/delete/<%= user._id %>">Delete User</a>
                        </div>
                    </div>

                <% }) %>
            <% } else {%>
                <h2>No User Available</h2>
            <% } %>
        </div>
        
    </div>
</body>
</html>